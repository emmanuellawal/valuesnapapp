# ========================================
# Frontend Environment Configuration
# ========================================
# Copy this file to .env and fill in values.
# NEVER commit .env to version control!

# ========================================
# Mock Mode Toggle
# ========================================
# Set to 'true' to use mock services (no real API calls)
# Set to 'false' for production or real API testing
# Default: true (safe for development)
EXPO_PUBLIC_USE_MOCK=true

# ========================================
# Supabase Configuration
# ========================================
# Get credentials from: Supabase Dashboard → Settings → API
# Required when EXPO_PUBLIC_USE_MOCK=false
#
# EXPO_PUBLIC_SUPABASE_URL:
#   Your project's URL, e.g. https://abcdefgh.supabase.co
#   Found at: Dashboard → Settings → API → Project URL
#
# EXPO_PUBLIC_SUPABASE_ANON_KEY:
#   The PUBLIC (anon) key — safe to embed in the app bundle.
#   Found at: Dashboard → Settings → API → Project API keys → anon (public)
#
#   ⚠️  DO NOT use the service_role key here.
#       The service_role key bypasses Row Level Security and grants god-mode
#       database access. It belongs ONLY in backend/.env (SUPABASE_SERVICE_KEY).
#       If you accidentally put a service_role key here, rotate it immediately
#       in the Supabase Dashboard before continuing.
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key-here

# ========================================
# Backend API Configuration
# ========================================
# Backend API base URL
# Local development: http://localhost:8000
# Production: https://your-backend.railway.app
# Required when EXPO_PUBLIC_USE_MOCK=false
EXPO_PUBLIC_API_URL=http://localhost:8000
