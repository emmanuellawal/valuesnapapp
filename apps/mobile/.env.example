# ========================================
# Frontend Environment Configuration
# ========================================
# Copy this file to .env and fill in values.
# NEVER commit .env to version control!

# ========================================
# Mock Mode Toggle
# ========================================
# Set to 'true' to use mock services (no real API calls)
# Set to 'false' for production or real API testing
# Default: true (safe for development)
EXPO_PUBLIC_USE_MOCK=true

# ========================================
# Supabase Configuration
# ========================================
# Get credentials from: https://app.supabase.com/project/YOUR_PROJECT/settings/api
# Required when EXPO_PUBLIC_USE_MOCK=false
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key-here

# ========================================
# Backend API Configuration
# ========================================
# Backend API base URL
# Local development: http://localhost:8000
# Production: https://your-backend.railway.app
# Required when EXPO_PUBLIC_USE_MOCK=false
EXPO_PUBLIC_API_URL=http://localhost:8000
