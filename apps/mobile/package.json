{
  "name": "mobile",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "postinstall": "node ./scripts/patch-expo-ngrok.cjs",
    "patch:expo-ngrok": "node ./scripts/patch-expo-ngrok.cjs",
    "start": "expo start --port 8083",
    "start:lan": "expo start --lan --port 8083",
    "start:tunnel": "unset ANDROID_HOME && npx expo start --tunnel --port 8083",
    "android": "expo start --android",
    "ios": "expo start --ios --port 8083",
    "ios:lan": "expo start --lan --ios --port 8083",
    "ios:tunnel": "unset ANDROID_HOME && npx expo start --tunnel --ios --port 8083",
    "web": "expo start --web --port 8083",
    "test:screenshots": "playwright test tests/screenshots.spec.ts",
    "test:screenshots:ui": "playwright test tests/screenshots.spec.ts --ui",
    "test:screenshots:headed": "playwright test tests/screenshots.spec.ts --headed",
    "test:e2e:migration": "playwright test -c playwright.migration.config.ts tests/migration-flow.spec.ts",
    "test:prod-harness-guard": "rm -rf dist-prod-guard && env EXPO_NO_DOTENV=1 EXPO_PUBLIC_USE_MOCK=false EXPO_PUBLIC_SUPABASE_URL=https://guard.supabase.co EXPO_PUBLIC_SUPABASE_ANON_KEY=guard-anon-key EXPO_PUBLIC_API_URL=http://localhost:8000 npx expo export --platform web --output-dir dist-prod-guard && node ./scripts/assert-no-test-harness-in-prod.mjs dist-prod-guard",
    "test": "jest",
    "test:unit": "jest --testPathPattern='__tests__'",
    "lint": "expo lint --max-warnings 0"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@hookform/resolvers": "^5.2.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/native": "^7.1.8",
    "@supabase/supabase-js": "^2.100.1",
    "base64-arraybuffer": "^1.0.2",
    "expo": "~54.0.30",
    "expo-camera": "~17.0.10",
    "expo-clipboard": "~8.0.8",
    "expo-constants": "~18.0.12",
    "expo-file-system": "~19.0.21",
    "expo-font": "~14.0.10",
    "expo-image-picker": "^17.0.10",
    "expo-linking": "~8.0.11",
    "expo-router": "~6.0.21",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-web-browser": "~15.0.10",
    "jest-expo": "~54.0.17",
    "nativewind": "^4.2.3",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-hook-form": "^7.72.0",
    "react-native": "0.81.5",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.5.1",
    "tailwindcss": "^3.4.18",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@expo/ngrok": "^4.1.3",
    "@playwright/test": "^1.57.0",
    "@types/jest": "^30.0.0",
    "@types/react": "~19.1.0",
    "@types/react-test-renderer": "^19.1.0",
    "eslint": "^9.0.0",
    "eslint-config-expo": "~10.0.0",
    "react-test-renderer": "19.1.0",
    "typescript": "~5.9.2"
  },
  "jest": {
    "preset": "jest-expo",
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@sentry/react-native|native-base|react-native-svg|@react-native-async-storage/async-storage)"
    ],
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/$1",
      "@react-native-async-storage/async-storage": "<rootDir>/node_modules/@react-native-async-storage/async-storage/jest/async-storage-mock.js"
    },
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/tests/"
    ]
  },
  "private": true
}
